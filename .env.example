TELEGRAM_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here
DATABASE_URL=jobs.db

# Job Sources - Add comma-separated URLs
RSS_URLS=https://remoteok.com/api/v0/sites_feed?category=programming, https://weworkremotely.com/categories/remote-programming-jobs.rss, https://remotive.com/remote-jobs/feed.xml
INSTAGRAM_ACCOUNTS=company_username1, company_username2
COMPANY_CAREER_PAGES=https://www.google.com/careers, https://www.amazon.jobs/, https://www.microsoft.com/en-us/careers

# Notification Settings
JOB_KEYWORDS=python,developer,engineer,java,nodejs,react,fullstack
SCRAPE_INTERVAL_MINUTES=15
LOG_LEVEL=INFO
TELEGRAM_PARSE_MODE=Markdown
